#: jsapp/js/components/passwordStrength.component.tsx:19
msgid "Use a few words, avoid common phrases"
msgstr "ប្រើប្រាស់ពីរបីពាក្យ ជៀសវាងឃ្លាទូទៅនានា"

#: jsapp/js/components/passwordStrength.component.tsx:20
msgid "No need for symbols, digits, or uppercase letters"
msgstr "មិនត្រូវការនិមិត្តសញ្ញា លេខ ឬអក្សរធំទេ"

#: jsapp/js/components/passwordStrength.component.tsx:21
msgid "Add another word or two. Uncommon words are better."
msgstr "បញ្ចូលមួយ ឬពីរពាក្យទៀត។ ពាក្យគេមិនប្រើទូទៅគឺកាន់តែល្អ។"

#: jsapp/js/components/passwordStrength.component.tsx:22
msgid "Straight rows of keys are easy to guess"
msgstr "គ្រាប់ចុចតាមជួរដេកត្រង់គឺងាយស្រួលទាយ"

#: jsapp/js/components/passwordStrength.component.tsx:23
msgid "Short keyboard patterns are easy to guess"
msgstr "លំនំាក្ដារចុចខ្លីគឺងាយស្រួលទាយ"

#: jsapp/js/components/passwordStrength.component.tsx:24
msgid "Use a longer keyboard pattern with more turns"
msgstr "ប្រើលំនំាក្ដារចុចកាន់តែវែងដោយមានការបត់បែនកាន់តែច្រើន"

#: jsapp/js/components/passwordStrength.component.tsx:25
msgid "Repeats like \"aaa\" are easy to guess"
msgstr "អក្សរដដែលៗដូចជា \"aaa\" គឺងាយស្រួលទាយ"

#: jsapp/js/components/passwordStrength.component.tsx:27
msgid "Repeats like \"abcabcabc\" are only slightly harder to guess than \"abc\""
msgstr "អក្សរដដែលៗដូចជា \"abcabcabc\" គឺរៀងពិបាកទាយ​ជាង \"abc\" តែបន្តិចប៉ុណ្ណោះ"

#: jsapp/js/components/passwordStrength.component.tsx:29
msgid "Avoid repeated words and characters"
msgstr "ជៀសវាងពាក្យ និងតួអក្សរដដែលៗ"

#: jsapp/js/components/passwordStrength.component.tsx:30
msgid "Sequences like abc or 6543 are easy to guess"
msgstr "លំដាប់ដូចជា abc ឬ 6543 គឺងាយស្រួលទាយ"

#: jsapp/js/components/passwordStrength.component.tsx:31
msgid "Avoid sequences"
msgstr "ជៀសវាងលំដាប់នានា"

#: jsapp/js/components/passwordStrength.component.tsx:32
msgid "Recent years are easy to guess"
msgstr "ឆ្នាំថ្មីៗគឺងាយស្រួលទាយ"

#: jsapp/js/components/passwordStrength.component.tsx:33
msgid "Avoid recent years"
msgstr "ជៀសវាងឆ្នាំថ្មីៗ"

#: jsapp/js/components/passwordStrength.component.tsx:34
msgid "Avoid years that are associated with you"
msgstr "ជៀសវាងឆ្នាំទាំងឡាយណាដែលទាក់ទងនឹងអ្នក"

#: jsapp/js/components/passwordStrength.component.tsx:35
msgid "Dates are often easy to guess"
msgstr "ជារឿយៗកាលបរិច្ឆេទគឺងាយស្រួលទាយ"

#: jsapp/js/components/passwordStrength.component.tsx:36
msgid "Avoid dates and years that are associated with you"
msgstr "ជៀសវាងកាលបរិច្ឆេទ និងឆ្នាំនានាដែលទាក់ទងនឹងអ្នក"

#: jsapp/js/components/passwordStrength.component.tsx:37
msgid "This is a top-10 common password"
msgstr "នេះគឺជាពាក្យសម្ងាត់ទូទៅដ៏ពេញនិយមចំនួន 10"

#: jsapp/js/components/passwordStrength.component.tsx:38
msgid "This is a top-100 common password"
msgstr "នេះគឺជាពាក្យសម្ងាត់ទូទៅដ៏ពេញនិយមចំនួន 100"

#: jsapp/js/components/passwordStrength.component.tsx:39
msgid "This is a very common password"
msgstr "នេះជាពាក្យសម្ងាត់ទូទៅបំផុត"

#: jsapp/js/components/passwordStrength.component.tsx:40
msgid "This is similar to a commonly used password"
msgstr "នេះគឺស្រដៀងនឹងពាក្យសម្ងាត់ដែលបានប្រើជាទូទៅ"

#: jsapp/js/components/passwordStrength.component.tsx:41
msgid "A word by itself is easy to guess"
msgstr "ពាក្យតែមួយគឺងាយស្រួលទាយ"

#: jsapp/js/components/passwordStrength.component.tsx:42
msgid "Names and surnames by themselves are easy to guess"
msgstr "ឈ្មោះ និងនាមត្រកូលគឺងាយស្រួលទាយ"

#: jsapp/js/components/passwordStrength.component.tsx:43
msgid "Common names and surnames are easy to guess"
msgstr "ឈ្មោះ និងនាមត្រកូលទូទៅគឺងាយស្រួលទាយ"

#: jsapp/js/components/passwordStrength.component.tsx:44
msgid "Capitalization doesn't help very much"
msgstr "ការសរសេរជាអក្សរធំ​ជួយអ្វីមិនបានច្រើនទេ"


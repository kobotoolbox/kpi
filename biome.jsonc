{
  "$schema": "https://biomejs.dev/schemas/2.4.8/schema.json",
  "files": {
    "includes": [
      "**/jsapp/**",
      "!**/jsapp/compiled",
      // Ignore minified committed JS files.
      "!**/*.css",
      "!**/*.min.js",
      "!**/*-min.js",
      "!**/bootstrap*.js",
      "!**/jquery*.js"
    ]
  },
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "formatter": {
    "enabled": true, // Default.
    "formatWithErrors": false, // Default.
    "attributePosition": "auto", // Default.
    "indentStyle": "space", // Default is tab, we use space due imho the real standard.
    "indentWidth": 2, // Default.
    "lineWidth": 120, // Default is 80, we use 120 due wider monitors nowadays.
    "lineEnding": "lf" // Default.
  },
  "javascript": {
    "jsxRuntime": "reactClassic", // TODO: check babel and typescript and use the transparent runtime.
    "formatter": {
      "arrowParentheses": "always", // Default.
      "bracketSameLine": false, // Default.
      "bracketSpacing": true, // Default.
      "jsxQuoteStyle": "single", // Default is double, we use single for a cleaner look.
      "quoteProperties": "asNeeded", // Default.
      "semicolons": "asNeeded", // Default is always, we use asNeeded for a cleaner look.
      "trailingCommas": "all", // Default
      "attributePosition": "auto", // Default.
      "quoteStyle": "single" // Default is double, we use single for a cleaner look.
    }
  },
  "assist": {
    "actions": {
      "source": {
        "organizeImports": {
          "level": "on",
          "options": {
            "groups": [
              "react", // special line for React
              ":BLANK_LINE:",
              ":PACKAGE:", // External dependencies
              ":BLANK_LINE:",
              "#*/**", // Internal global imports
              ":BLANK_LINE:",
              "../**", // Local parent imports
              ":BLANK_LINE:",
              "./**" // Local sibling/child imports
            ]
          }
        }
      }
    }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      // Note: amounts are updated on Mar 23, 2026 by running `npm run lint:biome-summary` and asking LLM to transform.
      "correctness": {
        "noEmptyPattern": "off", // Recommended rule. TODO: review 6 cases and enable.
        "noInnerDeclarations": "off", // Recommended rule. TODO: review 19 cases and enable.
        "noSwitchDeclarations": "off", // Recommended rule. TODO: review 2 cases and enable.
        "noUnsafeOptionalChaining": "off", // Recommended rule. TODO: review 5 cases and enable.
        "noUnusedFunctionParameters": "off", // Recommended rule. TODO: review 14 cases and enable.
        "noUnusedImports": "error", // Enable all safely fixable rules.
        "noUnusedVariables": "off", // Recommended rule. TODO: review 33 cases and enable.
        "useExhaustiveDependencies": "off", // Recommended rule. TODO: review 103 cases and enable.
        "useHookAtTopLevel": "off", // Recommended rule. TODO: review 28 cases and enable.
        "useJsxKeyInIterable": "off", // Recommended rule. TODO: review 1 cases and enable.
        "useParseIntRadix": "off" // Recommended rule. TODO: review 16 cases and enable.
      },
      "suspicious": {
        "noArrayIndexKey": "off", // Recommended rule. TODO: review 39 cases and enable.
        "noAssignInExpressions": "off", // Recommended rule. TODO: review 2 cases and enable.
        "noConfusingVoidType": "off", // Recommended rule. TODO: review 43 cases and enable.
        "noControlCharactersInRegex": "off", // Recommended rule. TODO: review 4 cases and enable.
        "noDoubleEquals": "off", // Recommended rule. TODO: review 9 cases and enable.
        "noExplicitAny": "off", // Recommended rule. TODO: review 394 cases and enable.
        "noImplicitAnyLet": "off", // Recommended rule. TODO: review 40 cases and enable.
        "noPrototypeBuiltins": "off", // Recommended rule. TODO: review 13 cases and enable.
        "noReactSpecificProps": "off", // We use React.
        "noRedeclare": "off", // Recommended rule. TODO: review 1 case and enable.
        "noShadowRestrictedNames": "off", // Recommended rule. TODO: review 2 cases and enable.
        "noVar": "off", // Recommended rule. TODO: review 90 cases and enable.
        "useIsArray": "off", // Recommended rule. TODO: review 3 cases and enable.
        "useIterableCallbackReturn": "off" // Recommended rule. TODO: review 25 cases and enable.
      },
      "security": {
        "noBlankTarget": "off", // Not a problem for modern browsers; see 2021 update, see https://mathiasbynens.github.io/rel-noopener/#recommendations.
        "noDangerouslySetInnerHtml": "off" // Recommended rule. TODO: review 11 cases and enable.
      },
      "complexity": {
        "noArguments": "off", // Recommended rule. TODO: review 6 cases and enable.
        "noBannedTypes": "off", // Recommended rule. TODO: review 282 cases and enable.
        "noCommaOperator": "off", // Recommended rule. TODO: review 7 cases and enable.
        "noExtraBooleanCast": "off", // Recommended rule. TODO: review 5 cases and enable.
        "noForEach": "off", // Recommended rule. TODO: review 240 cases and enable.
        "noUselessConstructor": "off", // Recommended rule. TODO: review 1 cases and enable.
        "noUselessFragments": "off", // Recommended rule. TODO: review 15 cases and enable.
        "noUselessSwitchCase": "off", // Recommended rule. TODO: review 2 cases and enable.
        "noUselessTernary": "off", // Recommended rule. TODO: review 4 cases and enable.
        "noUselessUndefinedInitialization": "error", // Enable all safely fixable rules.
        "useIndexOf": "off", // Recommended rule. TODO: review 1 cases and enable.
        "useLiteralKeys": "off", // Recommended rule. TODO: review 29 cases and enable.
        "useOptionalChain": "off", // Recommended rule. TODO: review 37 cases and enable.
        "useWhile": "error" // Enable all safely fixable rules.
      },
      "performance": {
        "noAccumulatingSpread": "off", // Recommended rule. TODO: review 1 cases and enable.
        "noDelete": "off" // Recommended rule. TODO: review 9 cases and enable.
      },
      "a11y": {
        "noLabelWithoutControl": "off", // Recommended rule. TODO: review 58 cases and enable.
        "noNoninteractiveTabindex": "off", // Recommended rule. TODO: review 1 cases and enable.
        "noPositiveTabindex": "off", // Recommended rule. TODO: review 1 cases and enable.
        "noStaticElementInteractions": "off", // Recommended rule. TODO: review 20 cases and enable.
        "noSvgWithoutTitle": "off", // Recommended rule. TODO: review 1 cases and enable.
        "useAltText": "off", // Recommended rule. TODO: review 1 cases and enable.
        "useAriaPropsSupportedByRole": "off", // Recommended rule. TODO: review 1 cases and enable.
        "useButtonType": "off", // Recommended rule. TODO: review 31 cases and enable.
        "useIframeTitle": "off", // Recommended rule. TODO: review 4 cases and enable.
        "useKeyWithClickEvents": "off", // Recommended rule. TODO: review 24 cases and enable.
        "useMediaCaption": "off", // Recommended rule. TODO: review 2 cases and enable.
        "useValidAnchor": "off" // Recommended rule. TODO: review 4 cases and enable.
      },
      "style": {
        "noImplicitBoolean": "off", // Enable all safely fixable rules, except this for a cleaner look.
        "noInferrableTypes": "error", // Enable all safely fixable rules.
        "noNegationElse": "error", // Enable all safely fixable rules.
        "noNonNullAssertion": "off", // Recommended rule. TODO: review 81 cases and enable.
        "noParameterAssign": "off", // Recommended rule. TODO: review 26 cases and enable.
        "noUnusedTemplateLiteral": "off", // Recommended rule. TODO: review 54 cases and enable.
        "noUselessElse": "off", // Recommended rule. TODO: review 167 cases and enable.
        "noYodaExpression": "error", // Enable all safely fixable rules.
        "useAsConstAssertion": "error", // Enable all safely fixable rules.
        "useCollapsedElseIf": "error", // Enable all safely fixable rules.
        "useExportType": "error", // Enable all safely fixable rules.
        "useNamingConvention": "off", // TODO: Enable all safely fixable rules.
        "useNodeAssertStrict": "error", // Enable all safely fixable rules.
        "useSelfClosingElements": "error", // Enable all safely fixable rules.
        "useSingleVarDeclarator": "off", // Recommended rule. TODO: review 8 cases and enable.
        "useTemplate": "off" // Recommended rule. TODO: review 88 cases and enable.
      }
    }
  }
}
